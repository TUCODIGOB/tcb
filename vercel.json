{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/chat.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/generar-pdf.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "redirects": [
    { "source": "/Aviso-Legal", "destination": "/aviso-legal", "permanent": true },
    { "source": "/Politica-De-Privacidad", "destination": "/politica-de-privacidad", "permanent": true },
    { "source": "/Politica-De-Cookies", "destination": "/politica-de-cookies", "permanent": true },
    { "source": "/Terminos-Y-Condiciones", "destination": "/terminos-y-condiciones", "permanent": true }
  ]
}
